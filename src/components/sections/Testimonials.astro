---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['testimonials'];
}

const { t } = Astro.props;
---

<section class="bg-gray-50 py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-3">{t.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display text-navy">
        {t.title}
      </h2>
    </div>

    <!-- Cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {t.items.map(({ text, name, school, time, avatar }) => (
        <article class="bg-white rounded-xl border border-gray-100 p-7 shadow-sm">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-5">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-gray-600 text-sm leading-relaxed mb-6">{text}</p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gray-200 overflow-hidden shrink-0">
              <img src={avatar} alt={name} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div>
              <p class="text-navy font-semibold text-sm">{name}</p>
              <p class="text-gray-400 text-xs">{school} · {time}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Google rating -->
    <div class="flex justify-center mt-12">
      <div class="inline-flex items-center gap-3 bg-white border border-gray-200 rounded-full px-6 py-3 shadow-sm">
        <div class="flex gap-0.5">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span class="text-navy font-bold">4.9</span>
        <span class="text-gray-400 text-sm">{t.googleRating}</span>
      </div>
    </div>
  </div>
</section>

const services = t.items.map((item, i) => ({ ...item, icon: icons[i] }));
---

<section id="services" class="bg-white py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-3">{t.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display text-navy mb-4">
        {t.title}
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        {t.subtitle}
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map(({ icon, title, description }) => (
        <article class="group p-6 rounded-xl border border-gray-100 hover:border-brand/20 hover:shadow-lg hover:shadow-brand/5 transition-all duration-300">
          <div class="flex justify-end mb-5">
            <div class="w-12 h-12 rounded-lg bg-brand/5 text-brand flex items-center justify-center group-hover:bg-brand group-hover:text-white transition-colors">
              <Fragment set:html={icon} />
            </div>
          </div>
          <h3 class="text-navy font-bold text-lg mb-2">{title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

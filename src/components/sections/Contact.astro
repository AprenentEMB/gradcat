---
import type { Lang, Translations } from '../../i18n/translations';

interface Props {
  t: Translations['contact'];
  lang: Lang;
}

const { t, lang } = Astro.props;
const sectionId = lang === 'ca' ? 'contacte' : 'contacto';

const appsScriptUrl = import.meta.env.PUBLIC_APPS_SCRIPT_URL ?? '';
---

<section id={sectionId} class="bg-gray-50 py-24 px-6 border-t border-gray-100">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-3">{t.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display text-navy mb-4">
        {t.title}
      </h2>
      <p class="text-gray-500 text-lg">
        {t.subtitle}
      </p>
    </div>

    <!-- Form -->
    <div class="bg-white border border-gray-200 rounded-2xl p-8 sm:p-10 shadow-sm">
      <form id="contact-form" class="space-y-6" data-script-url={appsScriptUrl} data-msg-success={t.formSuccess} data-msg-error={t.formError} data-msg-sending={t.formSending}>
        {/* Honeypot antispam */}
        <input type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" />
        <!-- Phone -->
        <div>
          <label for="phone" class="block text-navy text-sm font-semibold mb-2">{t.phoneLabel}</label>
          <input
            type="tel" id="phone" name="phone" placeholder="600 000 000" required
            maxlength="9" pattern="[6789][0-9]{8}"
            class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand"
          />
          <div id="contact-phone-hint" class="hidden mt-1 text-xs text-blue-500 items-center gap-1">
            <svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/></svg>
            <span id="contact-phone-hint-text"></span>
          </div>
        </div>

        <!-- Dubtes -->
        <div>
          <label for="message" class="block text-navy text-sm font-semibold mb-2">{t.messageLabel}</label>
          <textarea
            id="message" name="message" rows="4"
            placeholder={t.messagePlaceholder}
            class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand resize-none"
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          id="submit-btn"
          class="w-full bg-brand text-white font-semibold text-base py-4 rounded-lg hover:bg-brand-light transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <span id="btn-text">{t.submitBtn}</span>
          <span id="btn-loading" class="hidden"></span>
        </button>

        <!-- Feedback -->
        <div id="form-success" class="hidden text-center py-3 px-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm font-medium"></div>
        <div id="form-error" class="hidden text-center py-3 px-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm font-medium"></div>

        <p class="text-gray-400 text-xs text-center">
          {t.disclaimer}
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  function sanitizePhone(input: HTMLInputElement, hintEl?: HTMLElement | null, hintTextId?: string) {
    const hadPlus = input.value.includes('+');
    let val = input.value.replace(/\D/g, '');
    let stripped = hadPlus;
    if ((val.startsWith('34') || val.startsWith('0034')) && val.length > 9) {
      val = val.startsWith('0034') ? val.slice(4) : val.slice(2);
      stripped = true;
    }
    if (val.length > 9) val = val.slice(0, 9);
    input.value = val;

    if (hintEl && stripped) {
      const lang = document.documentElement.lang || 'ca';
      const hintText = hintTextId ? document.getElementById(hintTextId) : null;
      if (hintText) hintText.textContent = lang === 'es'
        ? 'Escribe el teléfono sin prefijo, ej: 687517812'
        : 'Escriu el telèfon sense prefix, ex: 687517812';
      hintEl.classList.remove('hidden');
      hintEl.classList.add('flex');
      clearTimeout((hintEl as any)._hintTimer);
      (hintEl as any)._hintTimer = setTimeout(() => {
        hintEl.classList.add('hidden');
        hintEl.classList.remove('flex');
      }, 3000);
    }
  }

  const contactPhoneInput = document.getElementById('phone') as HTMLInputElement | null;
  const contactPhoneHint = document.getElementById('contact-phone-hint') as HTMLElement | null;
  contactPhoneInput?.addEventListener('input', () => sanitizePhone(contactPhoneInput, contactPhoneHint, 'contact-phone-hint-text'));

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const scriptUrl = form.dataset.scriptUrl;
      if (!scriptUrl) {
        console.error('Apps Script URL no configurada');
        return;
      }

      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const btnText = document.getElementById('btn-text') as HTMLElement;
      const btnLoading = document.getElementById('btn-loading') as HTMLElement;
      const successMsg = document.getElementById('form-success') as HTMLElement;
      const errorMsg = document.getElementById('form-error') as HTMLElement;

      const phone = (document.getElementById('phone') as HTMLInputElement).value;
      const message = (document.getElementById('message') as HTMLTextAreaElement).value;
      const lang = document.documentElement.lang || 'ca';
      const referit = localStorage.getItem('referit') || '';

      const msgSending = form.dataset.msgSending || 'Enviant...';
      const msgSuccess = form.dataset.msgSuccess || '';
      const msgError = form.dataset.msgError || '';

      submitBtn.disabled = true;
      btnText.classList.add('hidden');
      btnLoading.textContent = msgSending;
      btnLoading.classList.remove('hidden');
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      try {
        await fetch(scriptUrl, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'create', phone, message, lang, canal: 'Web', referit }),
        });

        form.reset();
        successMsg.textContent = msgSuccess;
        successMsg.classList.remove('hidden');

        document.dispatchEvent(new CustomEvent('open-info-modal', { detail: { phone } }));
      } catch {
        errorMsg.textContent = msgError;
        errorMsg.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        btnText.classList.remove('hidden');
        btnLoading.classList.add('hidden');
      }
    });
  }
</script>

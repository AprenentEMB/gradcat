---
---

<section id="contacto" class="bg-gray-50 py-24 px-6 border-t border-gray-100">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-3">Contacto</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display text-navy mb-4">
        Cuéntanos tu graduación
      </h2>
      <p class="text-gray-500 text-lg">
        Rellena el formulario y te enviamos un presupuesto personalizado en menos de 24h.
      </p>
    </div>

    <!-- Form -->
    <div class="bg-white border border-gray-200 rounded-2xl p-8 sm:p-10 shadow-sm">
      <form action="#" method="POST" class="space-y-6">
        <!-- Row 1 -->
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-navy text-sm font-semibold mb-2">Nombre</label>
            <input
              type="text" id="name" name="name" placeholder="Tu nombre" required
              class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand"
            />
          </div>
          <div>
            <label for="email" class="block text-navy text-sm font-semibold mb-2">Email</label>
            <input
              type="email" id="email" name="email" placeholder="tu@email.com" required
              class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand"
            />
          </div>
        </div>

        <!-- Row 2 -->
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="phone" class="block text-navy text-sm font-semibold mb-2">Teléfono</label>
            <input
              type="tel" id="phone" name="phone" placeholder="+34 600 000 000" required
              class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand"
            />
          </div>
          <div>
            <label for="school" class="block text-navy text-sm font-semibold mb-2">Centro educativo</label>
            <input
              type="text" id="school" name="school" placeholder="Nombre del instituto"
              class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand"
            />
          </div>
        </div>

        <!-- Row 3 -->
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="type" class="block text-navy text-sm font-semibold mb-2">Tipo de graduación</label>
            <select
              id="type" name="type" required
              class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand appearance-none cursor-pointer"
            >
              <option value="" disabled selected>Selecciona</option>
              <option value="eso">ESO</option>
              <option value="bachillerato">Bachillerato</option>
              <option value="selectividad">Selectividad</option>
              <option value="universidad">Universidad</option>
              <option value="otro">Otro</option>
            </select>
          </div>
          <div>
            <label for="people" class="block text-navy text-sm font-semibold mb-2">Número de personas</label>
            <input
              type="number" id="people" name="people" placeholder="100" min="50"
              class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand"
            />
          </div>
        </div>

        <!-- Message -->
        <div>
          <label for="message" class="block text-navy text-sm font-semibold mb-2">Mensaje</label>
          <textarea
            id="message" name="message" rows="4"
            placeholder="Cuéntanos más sobre lo que buscáis..."
            class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand resize-none"
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full bg-brand text-white font-semibold text-base py-4 rounded-lg hover:bg-brand-light transition-colors"
        >
          Enviar solicitud
        </button>

        <p class="text-gray-400 text-xs text-center">
          Te respondemos en menos de 24h. Sin compromiso.
        </p>
      </form>
    </div>
  </div>
</section>

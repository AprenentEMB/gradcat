---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['gallery'];
}

const { t } = Astro.props;

const imageSrcs = [
  { src: '/graduacions/1.webp', span: 'col-span-2 row-span-2' },
  { src: '/graduacions/2.webp', span: '' },
  { src: '/graduacions/3.webp', span: '' },
  { src: '/graduacions/4.webp', span: '' },
  { src: '/graduacions/5.webp', span: '' },
];

const images = imageSrcs.map((img, i) => ({ ...img, alt: t.images[i]?.alt ?? '' }));
---

<section id="galeria" class="bg-gray-50 py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-3">{t.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display text-navy mb-4">
        {t.title}
      </h2>
      <p class="text-gray-500 text-lg">
        {t.subtitle}
      </p>
    </div>

    <!-- Photo grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 auto-rows-[200px] lg:auto-rows-[220px]">
      {images.map(({ src, alt, span }) => (
        <div class:list={['rounded-xl overflow-hidden group', span]}>
          <img
            src={src}
            alt={alt}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

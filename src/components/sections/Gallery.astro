---
import { Image } from 'astro:assets';
import type { Translations } from '../../i18n/translations';

// Importa les imatges (Astro les optimitzarà durant el build)
import img1 from '../../assets/graduacions/1.webp';
import img2 from '../../assets/graduacions/2.webp';
import img3 from '../../assets/graduacions/3.webp';
import img4 from '../../assets/graduacions/4.webp';
import img5 from '../../assets/graduacions/5.webp';
interface Props {
  t: Translations['gallery'];
}

const { t } = Astro.props;

// Afegim les imatges directament a l'array
const imageSrcs = [
  { src: img1, span: 'col-span-2 row-span-2' },
  { src: img2, span: '' },
  { src: img3, span: '' },
  { src: img4, span: '' },
  { src: img5, span: '' },
];

const images = imageSrcs.map((img, i) => ({ ...img, alt: t.images[i]?.alt ?? '' }));
---

<section id="galeria" class="bg-gray-50 py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-3">{t.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display text-navy mb-4">
        {t.title}
      </h2>
      <p class="text-gray-500 text-lg">
        {t.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 auto-rows-[200px] lg:auto-rows-[220px]">
      {images.map(({ src, alt, span }, i) => (
        <div class:list={['rounded-xl overflow-hidden group', span]}>
          <Image
            src={src}
            alt={alt}
            width={i === 0 ? 1200 : 640}
            height={i === 0 ? 880 : 460}
            quality={80}
            loading={i === 0 ? 'eager' : 'lazy'}
            class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500"
          />
        </div>
      ))}
    </div>
  </div>
</section>
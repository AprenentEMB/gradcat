---
const PHONE_HREF = 'tel:+34605508397';
const EMAIL = 'info@graduacions.cat';
---

<footer class="bg-navy py-16 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/></svg>
          <span class="text-lg font-extrabold text-white">GRAD-CAT</span>
        </div>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs mb-5">
          Organizamos fiestas de graduación inolvidables en Barcelona. ESO, Bachillerato, Selectividad y universidad.
        </p>
        <div class="flex gap-3">
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/50 hover:text-white hover:border-white/30 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="#" aria-label="TikTok" class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/50 hover:text-white hover:border-white/30 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.22 6.22 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.75a8.27 8.27 0 004.84 1.56V6.88a4.85 4.85 0 01-1.07-.19z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Servicios</h4>
        <ul class="space-y-2.5 text-white/40 text-sm">
          <li><a href="#servicios" class="hover:text-white transition-colors">Salas Exclusivas</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">Cenas & Catering</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">DJ & Música</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">Fotografía & Aftermovie</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">Photocall</a></li>
        </ul>
      </div>

      <!-- Packs -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Packs</h4>
        <ul class="space-y-2.5 text-white/40 text-sm">
          <li><a href="#packs" class="hover:text-white transition-colors">Graduación ESO</a></li>
          <li><a href="#packs" class="hover:text-white transition-colors">Graduación Bachillerato</a></li>
          <li><a href="#packs" class="hover:text-white transition-colors">Graduación Selectividad</a></li>
          <li><a href="#contacto" class="hover:text-white transition-colors">Pack Personalizado</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contacto</h4>
        <ul class="space-y-2.5 text-white/40 text-sm">
          <li><a href={PHONE_HREF} class="hover:text-white transition-colors">605 508 397</a></li>
          <li><a href={`mailto:${EMAIL}`} class="hover:text-white transition-colors">{EMAIL}</a></li>
          <li>Barcelona, Catalunya</li>
          <li class="text-white/30">Atención 24/7</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-sm">&copy; 2025 Graduacions.cat. Todos los derechos reservados.</p>
      <p class="text-white/20 text-xs">Graduaciones Barcelona &middot; Fiestas de graduación ESO, Bachillerato, Selectividad</p>
    </div>
  </div>
</footer>

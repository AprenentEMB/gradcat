---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['faq'];
}

const { t } = Astro.props;

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.items.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
});
---

<script is:inline type="application/ld+json" set:html={faqSchema} />

<section class="bg-white py-24 px-6">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-3">FAQ</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display text-navy">
        {t.title}
      </h2>
    </div>

    <!-- Accordion -->
    <div class="flex flex-col gap-3">
      {t.items.map(({ question, answer }, index) => (
        <details class="faq-item group border border-gray-200 rounded-xl overflow-hidden hover:border-brand/30 transition-colors duration-200" open={index === 0}>
          <summary class="flex items-center justify-between cursor-pointer p-6 text-navy font-semibold text-sm sm:text-base list-none [&::-webkit-details-marker]:hidden">
            <span>{question}</span>
            <svg class="faq-chevron w-5 h-5 text-gray-400 shrink-0 ml-4 transition-transform duration-300 ease-in-out" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="faq-content">
            <div class="px-6 pb-6 pt-0 text-gray-500 text-sm leading-relaxed">
              <Fragment set:html={answer} />
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-content {
    overflow: hidden;
    height: 0;
    transition: height 0.35s ease;
  }

  .faq-chevron.is-open {
    transform: rotate(180deg);
  }
</style>

<script>
  function initFaq() {
    document.querySelectorAll<HTMLDetailsElement>('.faq-item:not([data-faq-init])').forEach((details) => {
      details.setAttribute('data-faq-init', 'true');

      const summary = details.querySelector('summary')!;
      const content = details.querySelector<HTMLElement>('.faq-content')!;
      const chevron = details.querySelector<HTMLElement>('.faq-chevron')!;

      // Sync initial state without animation
      if (details.open) {
        content.style.height = content.scrollHeight + 'px';
        chevron.classList.add('is-open');
      }

      summary.addEventListener('click', (e) => {
        e.preventDefault();

        if (details.open) {
          // Collapse: pin current height, then animate to 0
          content.style.height = content.scrollHeight + 'px';
          requestAnimationFrame(() => {
            content.style.height = '0px';
            chevron.classList.remove('is-open');
          });
          setTimeout(() => details.removeAttribute('open'), 350);
        } else {
          // Expand: open so content renders, measure, animate
          details.setAttribute('open', '');
          const target = content.scrollHeight;
          content.style.height = '0px';
          requestAnimationFrame(() => {
            content.style.height = target + 'px';
            chevron.classList.add('is-open');
          });
        }
      });
    });
  }

  initFaq();
  document.addEventListener('astro:page-load', initFaq);
</script>

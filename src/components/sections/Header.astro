---
import type { Lang, Translations } from '../../i18n/translations';

interface Props {
  t: Translations['header'];
  lang: Lang;
}

const { t, lang } = Astro.props;

const PHONE = '658 020 084';
const PHONE_HREF = 'tel:+34658020084';

// Aquestes variables ara sempre es recalcularan bé a cada canvi d'idioma
const currentLabel = lang === 'ca' ? 'CA' : 'ES';
const homeBase = lang === 'ca' ? '/' : '/es';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-brand/97 backdrop-blur-md border-b border-white/10 shadow-lg shadow-brand-dark/30" transition:persist="site-header">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center h-16 lg:h-17.5">

    <!-- Left: Logo + Nav -->
    <div class="flex items-center gap-10 flex-1">
      <a href={lang === 'ca' ? '/' : '/es'} class="flex shrink-0 opacity-95 hover:opacity-100 transition-opacity">
        <img src="/gradcat-icon.png" alt="Graduacions.cat" class="h-28 w-auto">
      </a>

    <nav aria-label="Navegació principal" class="hidden lg:flex items-center gap-1 font-semibold">
      <a href={lang === 'ca' ? '/serveis' : '/es/servicios'} class="relative text-white/85 hover:text-white text-sm px-3 py-2 rounded-lg hover:bg-white/10 transition-all duration-200">{t.services}</a>
      <a href={`${homeBase}#packs`} class="relative text-white/85 hover:text-white text-sm px-3 py-2 rounded-lg hover:bg-white/10 transition-all duration-200">{t.packs}</a>
      <a href={`${homeBase}#contact`} class="relative text-white/85 hover:text-white text-sm px-3 py-2 rounded-lg hover:bg-white/10 transition-all duration-200">{t.contact}</a>
      <a href={lang === 'ca' ? '/blog' : '/es/blog'} class="relative text-white/85 hover:text-white text-sm px-3 py-2 rounded-lg hover:bg-white/10 transition-all duration-200">{t.blog}</a>
    </nav>
    </div><!-- /left group -->

    <!-- Right: Phone + Lang + CTA -->
    <div class="flex items-center justify-end gap-1.5">

      <!-- Phone (desktop only) -->
      <a href={PHONE_HREF} class="hidden lg:flex items-center gap-2 text-white/75 hover:text-white transition-all duration-200 text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/10 group">
        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-white/10 group-hover:bg-white/20 transition-colors shrink-0">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </span>
        {PHONE}
      </a>

      <!-- Divider -->
      <span class="hidden lg:block w-px h-5 bg-white/15 mx-1"></span>

      <!-- Lang switcher -->
      <div class="hidden lg:block relative" id="lang-switcher">
        <button
          id="lang-btn"
          aria-haspopup="listbox"
          aria-expanded="false"
          class="flex items-center gap-1.5 text-white/75 hover:text-white text-sm font-medium border border-white/15 hover:border-white/35 hover:bg-white/10 rounded-lg px-3 py-2 transition-all duration-200"
        >
          <svg class="w-3.5 h-3.5 shrink-0 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253M3 12a8.96 8.96 0 00.284 2.253" />
          </svg>
          <span>{currentLabel}</span>
          <svg id="lang-chevron" class="w-3 h-3 transition-transform duration-200 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div
          id="lang-dropdown"
          role="listbox"
          class="absolute right-0 top-full mt-2.5 w-44 bg-white rounded-2xl shadow-2xl shadow-gray-900/15 border border-gray-100/80 overflow-hidden hidden"
        >
          <a
            href="/"
            data-astro-reload
            role="option"
            aria-selected={lang === 'ca'}
            class:list={[
              'flex items-center gap-3 px-4 py-3.5 text-sm font-medium transition-colors',
              lang === 'ca'
                ? 'bg-brand/5 text-brand'
                : 'text-gray-600 hover:bg-gray-50',
            ]}
          >
            <span>Català</span>
            {lang === 'ca' && (
              <svg class="w-4 h-4 ml-auto text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            )}
          </a>
          <div class="border-t border-gray-100"></div>
          <a
            href="/es"
            data-astro-reload
            role="option"
            aria-selected={lang === 'es'}
            class:list={[
              'flex items-center gap-3 px-4 py-3.5 text-sm font-medium transition-colors',
              lang === 'es'
                ? 'bg-brand/5 text-brand'
                : 'text-gray-600 hover:bg-gray-50',
            ]}
          >
            <span>Español</span>
            {lang === 'es' && (
              <svg class="w-4 h-4 ml-auto text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            )}
          </a>
        </div>
      </div>

      <!-- CTA button (desktop) -->
      <button
        id="header-cta-btn"
        type="button"
        class="hidden lg:flex items-center gap-1.5 bg-white text-brand font-semibold text-sm px-5 py-2.5 rounded-xl hover:bg-gray-50 active:scale-[0.98] transition-all duration-200 shadow-sm shadow-black/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-brand ml-1"
      >
        {t.cta}
      </button>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-white/85 hover:text-white hover:bg-white/10 rounded-lg transition-all duration-200"
        aria-label={t.mobileMenuLabel}
        aria-expanded="false"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>

    </div><!-- /right group -->
  </div><!-- /container -->

  <div id="mobile-menu" class="hidden lg:hidden bg-white/98 backdrop-blur-sm border-t border-gray-100">
    <nav class="max-w-7xl mx-auto px-5 py-3 flex flex-col">
      <a href={PHONE_HREF} class="flex items-center gap-3 text-gray-600 text-sm font-medium py-3.5 border-b border-gray-100 group">
        <span class="flex items-center justify-center w-8 h-8 rounded-full bg-brand/8 group-hover:bg-brand/12 transition-colors shrink-0">
          <svg class="w-3.5 h-3.5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </span>
        {PHONE}
      </a>
      <a href={lang === 'ca' ? '/serveis' : '/es/servicios'} class="text-gray-700 hover:text-brand text-sm font-medium py-3.5 border-b border-gray-100 transition-colors">{t.services}</a>
      <a href={`${homeBase}#packs`} class="text-gray-700 hover:text-brand text-sm font-medium py-3.5 border-b border-gray-100 transition-colors">{t.packs}</a>
      <a href={`${homeBase}#contact`} class="text-gray-700 hover:text-brand text-sm font-medium py-3.5 border-b border-gray-100 transition-colors">{t.contact}</a>
      <a href={lang === 'ca' ? '/blog' : '/es/blog'} class="text-gray-700 hover:text-brand text-sm font-medium py-3.5 border-b border-gray-100 transition-colors">{t.blog}</a>

      <div class="pt-4 pb-2">
        <p class="text-[10px] text-gray-400 font-semibold uppercase tracking-widest mb-3">Idioma</p>
        <div class="flex gap-2">
          <a
            href="/"
            data-astro-reload
            class:list={[
              'flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 border',
              lang === 'ca'
                ? 'bg-brand text-white border-brand shadow-sm'
                : 'text-gray-500 border-gray-200 hover:border-brand/30 hover:text-brand',
            ]}
          >
           Català
          </a>
          <a
            href="/es"
            data-astro-reload
            class:list={[
              'flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 border',
              lang === 'es'
                ? 'bg-brand text-white border-brand shadow-sm'
                : 'text-gray-500 border-gray-200 hover:border-brand/30 hover:text-brand',
            ]}
          >
             Español
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  // 1. Inicialitzador segur per a Astro ViewTransitions
  const initHeaderEvents = () => {
    // LÒGICA DEL MODAL CTA
    const ctaBtn = document.getElementById('header-cta-btn');
    if (ctaBtn && !ctaBtn.hasAttribute('data-init')) {
      ctaBtn.setAttribute('data-init', 'true');
      ctaBtn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('open-contact-modal'));
      });
    }

 

    // LÒGICA DEL MENÚ MÒBIL
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (mobileBtn && mobileMenu && !mobileBtn.hasAttribute('data-init')) {
      mobileBtn.setAttribute('data-init', 'true');
      mobileBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !mobileMenu.classList.contains('hidden');
        mobileMenu.classList.toggle('hidden');
        mobileBtn.setAttribute('aria-expanded', String(!isOpen));
      });
    }

    // LÒGICA DEL SELECTOR D'IDIOMA
    const langBtn = document.getElementById('lang-btn');
    const langDropdown = document.getElementById('lang-dropdown');
    const langChevron = document.getElementById('lang-chevron');
    if (langBtn && langDropdown && langChevron && !langBtn.hasAttribute('data-init')) {
      langBtn.setAttribute('data-init', 'true');
      langBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const isOpen = !langDropdown.classList.contains('hidden');
        langDropdown.classList.toggle('hidden');
        langChevron.style.transform = isOpen ? '' : 'rotate(180deg)';
        langBtn.setAttribute('aria-expanded', String(!isOpen));
      });
    }
  };

  // 2. ESDEVENIMENT GLOBAL (CLICAR FORA) - Registrat només un cop
  if (!(window as any).globalCloseInitialized) {
    (window as any).globalCloseInitialized = true;
    
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      
      // Tancar menú mòbil si es clica fora o sobre un enllaç
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileBtn = document.getElementById('mobile-menu-btn');
      if (mobileMenu && !mobileMenu.classList.contains('hidden')) {
        const isOutside = !mobileMenu.contains(target) && !mobileBtn?.contains(target);
        if (isOutside || target.closest('a')) {
          mobileMenu.classList.add('hidden');
          if (mobileBtn) mobileBtn.setAttribute('aria-expanded', 'false');
        }
      }

      // Tancar selector d'idiomes si es clica fora o sobre un enllaç
      const langDropdown = document.getElementById('lang-dropdown');
      const langBtn = document.getElementById('lang-btn');
      const langChevron = document.getElementById('lang-chevron');
      if (langDropdown && !langDropdown.classList.contains('hidden')) {
        const isOutside = !langDropdown.contains(target) && !langBtn?.contains(target);
        if (isOutside || target.closest('a')) {
          langDropdown.classList.add('hidden');
          if (langChevron) langChevron.style.transform = '';
          if (langBtn) langBtn.setAttribute('aria-expanded', 'false');
        }
      }
    });
  }

  // Executar a la càrrega inicial i a cada navegació suau (View Transitions)
  initHeaderEvents();
  document.addEventListener('astro:page-load', initHeaderEvents);
</script>
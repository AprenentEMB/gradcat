---
import type { Lang, Translations } from '../../i18n/translations';

interface Props {
  t: Translations['header'];
  lang: Lang;
}

const { t, lang } = Astro.props;

const PHONE = '658 020 084';
const PHONE_HREF = 'tel:+34658020084';

const currentLabel = lang === 'ca' ? 'CA' : 'ES';
const homeBase = lang === 'ca' ? '/' : '/es';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-brand backdrop-blur-sm border-b border-gray-100" transition:persist="site-header">
  <div class="max-w-8xl mx-auto px-6 flex items-center justify-between h-16 lg:h-18 lg:pl-24 lg:pr-32">
    <!-- Logo -->
    <a href={lang === 'ca' ? '/' : '/es'} class="flex">
      <img src="/gradcat-icon.png" alt="Graduacions.cat" class="h-36 w-auto">
    </a>

    <!-- Phone -->
    <a href={PHONE_HREF} class="hidden md:flex items-center gap-2 text-white hover:text-gray-300 transition-colors text-sm font-medium">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
      </svg>
      {PHONE}
    </a>

    <!-- Nav -->
    <nav aria-label="Navegació principal" class="hidden lg:flex items-center gap-8">
      <a href={lang === 'ca' ? '/serveis' : '/es/servicios'} class="text-white hover:text-gray-300 text-sm font-medium transition-colors">{t.services}</a>
      <a href={`${homeBase}#packs`} class="text-white hover:text-gray-300 text-sm font-medium transition-colors">{t.packs}</a>
      <a href={`${homeBase}#contact`} class="text-white hover:text-gray-300 text-sm font-medium transition-colors">{t.contact}</a>
      <a href={lang === 'ca' ? '/blog' : '/es/blog'} class="text-white hover:text-gray-300 text-sm font-medium transition-colors">{t.blog}</a>

    </nav>

    <div class="hidden lg:flex items-center gap-3">
      <!-- Language switcher dropdown -->
      <div class="relative" id="lang-switcher">
        <button
          id="lang-btn"
          aria-haspopup="listbox"
          aria-expanded="false"
          class="flex items-center gap-1.5 text-white/80 hover:text-white text-sm font-medium border border-white/20 hover:border-white/40 rounded-lg px-3 py-2 transition-colors"
        >
          <!-- Globe icon -->
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253M3 12a8.96 8.96 0 00.284 2.253" />
          </svg>
          <span>{currentLabel}</span>
          <!-- Chevron -->
          <svg id="lang-chevron" class="w-3.5 h-3.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Dropdown -->
        <div
          id="lang-dropdown"
          role="listbox"
          class="absolute right-0 top-full mt-2 w-40 bg-white rounded-xl shadow-xl border border-gray-100 overflow-hidden hidden"
        >
          <a
            href="/"
            role="option"
            aria-selected={lang === 'ca'}
            class:list={[
              'flex items-center gap-3 px-4 py-3 text-sm font-medium transition-colors',
              lang === 'ca'
                ? 'bg-brand/5 text-brand'
                : 'text-gray-600 hover:bg-gray-50',
            ]}
          >
            <span class="text-base leading-none">🏴󠁥󠁳󠁣󠁴󠁿</span>
            <span>Català</span>
            {lang === 'ca' && (
              <svg class="w-4 h-4 ml-auto text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            )}
          </a>
          <div class="border-t border-gray-100"></div>
          <a
            href="/es"
            role="option"
            aria-selected={lang === 'es'}
            class:list={[
              'flex items-center gap-3 px-4 py-3 text-sm font-medium transition-colors',
              lang === 'es'
                ? 'bg-brand/5 text-brand'
                : 'text-gray-600 hover:bg-gray-50',
            ]}
          >
            <span class="text-base leading-none">🇪🇸</span>
            <span>Español</span>
            {lang === 'es' && (
              <svg class="w-4 h-4 ml-auto text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            )}
          </a>
        </div>
      </div>

      <!-- CTA -->
      <button
        id="header-cta-btn"
        type="button"
        class="bg-white text-brand font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-gray-50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
      >
        {t.cta}
      </button>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden text-gray-500 hover:text-brand ml-3"
      aria-label={t.mobileMenuLabel}
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100">
    <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">
      <a href={PHONE_HREF} class="flex items-center gap-2 text-gray-600 text-sm font-medium py-3 border-b border-gray-50">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        {PHONE}
      </a>
      <a href={lang === 'ca' ? '/serveis' : '/es/servicios'} class="text-gray-600 hover:text-brand text-sm font-medium py-3 border-b border-gray-50">{t.services}</a>
      <a href={`${homeBase}#packs`} class="text-gray-600 hover:text-brand text-sm font-medium py-3 border-b border-gray-50">{t.packs}</a>
      <a href={`${homeBase}#contact`} class="text-gray-600 hover:text-brand text-sm font-medium py-3 border-b border-gray-50">{t.contact}</a>
      <a href={lang === 'ca' ? '/blog' : '/es/blog'} class="text-gray-600 hover:text-brand text-sm font-medium py-3 border-b border-gray-50">{t.blog}</a>

      <!-- Language switcher mobile -->
      <div class="py-3 border-t border-gray-100 mt-1">
        <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-2">Idioma</p>
        <div class="flex gap-2">
          <a
            href="/"
            class:list={[
              'flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors border',
              lang === 'ca'
                ? 'bg-brand/5 text-brand border-brand/20'
                : 'text-gray-500 border-gray-200 hover:border-gray-300',
            ]}
          >
            <span>🏴󠁥󠁳󠁣󠁴󠁿</span> Català
          </a>
          <a
            href="/es"
            class:list={[
              'flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors border',
              lang === 'es'
                ? 'bg-brand/5 text-brand border-brand/20'
                : 'text-gray-500 border-gray-200 hover:border-gray-300',
            ]}
          >
            <span>🇪🇸</span> Español
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      });
    });

    // Close mobile menu on view transition navigation
    document.addEventListener('astro:after-navigation', () => {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });
  }

  // Language dropdown
  const langBtn = document.getElementById('lang-btn');
  const langDropdown = document.getElementById('lang-dropdown');
  const langChevron = document.getElementById('lang-chevron');

  if (langBtn && langDropdown && langChevron) {
    langBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !langDropdown.classList.contains('hidden');
      langDropdown.classList.toggle('hidden');
      langChevron.style.transform = isOpen ? '' : 'rotate(180deg)';
      langBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    document.addEventListener('click', () => {
      langDropdown.classList.add('hidden');
      langChevron.style.transform = '';
      langBtn.setAttribute('aria-expanded', 'false');
    });

    // Close language dropdown on view transition navigation
    document.addEventListener('astro:after-navigation', () => {
      langDropdown.classList.add('hidden');
      langChevron.style.transform = '';
      langBtn.setAttribute('aria-expanded', 'false');
    });
  }

  // Header CTA → open contact modal
  const ctaBtn = document.getElementById('header-cta-btn');
  ctaBtn?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-contact-modal'));
  });
</script>

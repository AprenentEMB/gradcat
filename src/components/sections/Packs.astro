---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['packs'];
}

const { t } = Astro.props;
---

<section id="packs" class="bg-white py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-3">{t.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display text-navy mb-4">
        {t.title}
      </h2>
      <p class="text-gray-500 text-lg">
        {t.subtitle}
      </p>
    </div>

    <!-- Cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-3xl mx-auto">
      {t.items.map((pack) => (
        <div
          class:list={[
            'relative rounded-xl p-8 border flex flex-col transition-all',
            pack.popular
              ? 'border-brand shadow-lg shadow-brand/10 ring-1 ring-brand/20'
              : 'border-gray-200 hover:border-gray-300',
          ]}
        >
          {pack.popular && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="bg-brand text-white text-xs font-bold px-4 py-1.5 rounded-full">
                {t.popularLabel}
              </span>
            </div>
          )}

          <div class="text-center mb-6 mt-2">
            <h3 class="text-2xl font-extrabold text-navy mb-3">{pack.name}</h3>
            <span class="inline-block bg-gray-100 text-gray-500 text-sm font-medium px-4 py-1.5 rounded-full">
              {pack.age}
            </span>
          </div>

          <a
            href="#contacto"
            class:list={[
              'mt-auto block text-center font-semibold text-sm py-3.5 rounded-lg transition-all',
              pack.popular
                ? 'bg-brand text-white hover:bg-brand-light'
                : 'border border-gray-200 text-navy hover:border-brand hover:text-brand',
            ]}
          >
            {t.ctaBtn}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

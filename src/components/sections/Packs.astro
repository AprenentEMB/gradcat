---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['packs'];
}

const { t } = Astro.props;
---

<section id="packs" class="relative bg-white py-28 px-6 overflow-hidden">
  <!-- Brand glow background -->
  <div
    class="pointer-events-none absolute inset-0 flex items-center justify-center"
    aria-hidden="true"
  >
    <div
      class="h-150 w-225 rounded-full opacity-8 blur-[140px]"
      style="background: radial-gradient(ellipse at center, #173696 0%, #0f2567 60%, transparent 85%);"
    ></div>
  </div>

  <div class="relative max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-brand font-semibold text-sm tracking-widest uppercase mb-3">{t.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display text-navy mb-4">
        {t.title}
      </h2>
      <p class="text-gray-500 text-lg max-w-xl mx-auto">
        {t.subtitle}
      </p>
    </div>

    <!-- Cards — items-stretch so side cards share same height -->
    <div class="grid sm:grid-cols-3 gap-6 max-w-4xl mx-auto items-stretch group/packs">
      {t.items.map((pack) => (
        <div
          class:list={[
            'relative rounded-2xl flex flex-col transition-all duration-300',
            'group-hover/packs:scale-[0.97] group-hover/packs:opacity-55',
            'hover:!scale-[1.03] hover:!opacity-100 hover:shadow-xl',
            pack.popular
              ? '-my-6 pack-gold px-8 pt-14 pb-10 z-10'
              : 'bg-gray-50 border border-gray-200 px-6 py-8 hover:!border-gray-300',
          ]}
        >
          {pack.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="bg-brand text-white text-xs font-bold px-5 py-1.5 rounded-full shadow-lg shadow-brand/30 whitespace-nowrap">
                {t.popularLabel}
              </span>
            </div>
          )}

          <!-- Pack name -->
          <div class="mb-5">
            <h3
              class:list={[
                'font-extrabold mb-2',
                pack.popular ? 'text-2xl text-[#3d1e00]' : 'text-xl text-navy',
              ]}
            >
              {pack.name}
            </h3>
            <div
              class:list={[
                'h-0.5 rounded-full',
                pack.popular ? 'w-10 bg-[#3d1e00]/40' : 'w-6 bg-gray-300',
              ]}
            ></div>
          </div>

          <!-- Divider -->
          <div
            class:list={[
              'border-t mb-5',
              pack.popular ? 'border-[#3d1e00]/20' : 'border-gray-200',
            ]}
          ></div>

          <!-- Features — grow to fill available space -->
          <ul class="space-y-2.5 grow">
            {pack.features.map((f) => (
              <li class="flex items-center gap-3 text-sm">
                <svg
                  class:list={['shrink-0 w-3.5 h-3.5', pack.popular ? 'text-[#3d1e00]/60' : 'text-brand/50']}
                  viewBox="0 0 8 14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="1,1 7,7 1,13"/>
                </svg>
                <span class:list={[pack.popular ? 'text-[#3d1e00]/80 font-medium' : 'text-gray-600']}>{f}</span>
              </li>
            ))}
          </ul>

          <!-- CTA button — pinned to bottom -->
          <button
            type="button"
            data-open-modal
            data-pack={pack.name}
            class:list={[
              'mt-8 w-full text-center font-bold text-sm py-3.5 rounded-xl transition-colors cursor-pointer',
              pack.popular
                ? 'bg-[#3d1e00] text-gold-light hover:bg-[#5c2e00] shadow-lg shadow-[#3d1e00]/30'
                : 'border border-gray-200 text-navy hover:border-brand hover:text-brand',
            ]}
          >
            {t.ctaBtn}
          </button>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-open-modal]');
    if (!btn) return;
    const pack = (btn as HTMLButtonElement).dataset.pack ?? '';
    document.dispatchEvent(new CustomEvent('open-contact-modal', { detail: { pack } }));
  });
</script>

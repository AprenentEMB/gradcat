---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['hero'];
}

const { t } = Astro.props;

const appsScriptUrl = import.meta.env.PUBLIC_APPS_SCRIPT_URL ?? '';
const embedOrigin = Astro.url.origin;
---

<section class="bg-gradient-to-br from-white via-white to-mist-200 pt-24 pb-20 lg:pt-32 lg:pb-24 px-6">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-8">

    <!-- Left: Text + Form -->
    <div class="flex-1 min-w-0 flex flex-col items-center lg:items-start">

      <!-- Pre-headline -->
      <p class="text-brand font-semibold text-xs lg:text-sm tracking-widest uppercase mb-4 text-center lg:text-left">
        {t.preheadline}
      </p>

      <!-- Headline -->
      <h1 class="font-headline leading-tight mb-4 lg:mb-6 text-center lg:text-left" transition:name="hero-heading">

  <span class="block text-4xl sm:text-5xl lg:text-5xl tracking-tight text-gray-500 mb-3 sm:mb-4" style="font-weight:200">
    {t.headline1}
  </span>

  <span class="block text-5xl sm:text-6xl lg:text-7xl tracking-tighter bg-linear-to-r from-brand-dark via-brand to-blue-400 bg-clip-text text-transparent pb-4" style="font-weight:800">
    {t.headline2}
  </span>

</h1>

      <!-- Subtitle -->
      <p class="font-light text-gray-500 text-base lg:text-lg leading-relaxed max-w-md mb-8 lg:mb-10 text-center lg:text-left">
        {t.subtitle}
      </p>

      <!-- Callback form card -->
      <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5 sm:p-6 w-full max-w-md shadow-sm">
        <p class="text-navy font-bold text-base lg:text-lg mb-4 text-center lg:text-left">{t.callbackTitle}</p>
        <form id="hero-form" class="flex flex-col sm:flex-row gap-2 sm:gap-3" data-script-url={appsScriptUrl} data-msg-success={t.formSuccess} data-msg-error={t.formError} data-msg-sending={t.formSending} data-msg-sent={t.formSent}>
          {/* Honeypot antispam */}
          <input type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" />
          <input
            type="tel"
            id="hero-phone"
            name="phone"
            maxlength="9"
            pattern="[6789][0-9]{8}"
            placeholder={t.phonePlaceholder}
            class="flex-1 min-w-0 bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand shadow-inner"
            required
          />
          <button
            type="submit"
            id="hero-submit-btn"
            class="w-full sm:w-auto bg-brand text-white font-semibold text-sm px-5 py-3 rounded-xl hover:bg-brand-light transition-all shadow-md hover:shadow-lg whitespace-nowrap cursor-pointer touch-manipulation"
          >
            <span id="hero-btn-text">{t.contactBtn}</span>
          </button>
        </form>
        <div id="hero-phone-hint" class="hidden mt-2 text-xs text-blue-500 items-center gap-1">
          <svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/></svg>
          <span id="hero-phone-hint-text"></span>
        </div>
        <div id="hero-success" class="hidden mt-3 text-green-600 text-xs font-medium"></div>
        <div id="hero-error" class="hidden mt-3 text-red-600 text-xs font-medium"></div>
        <p class="text-gray-500 text-xs font-medium mt-3 leading-relaxed">
          {t.callbackNote}
        </p>
      </div>

    </div>

    <!-- Right: Phone -->
   <div class="flex-shrink-0 flex justify-center lg:justify-end relative pb-8 lg:pb-0">
  <div class="relative w-[220px] sm:w-[240px] lg:w-[280px] group cursor-pointer" id="video-container">

    <div class="absolute -inset-2 sm:-inset-4 bg-gradient-to-tr from-brand via-gray-400 to-zinc-900 rounded-[3rem] blur-2xl opacity-40 group-hover:opacity-70 group-hover:scale-105 transition-all duration-700 ease-out z-0"></div>

    <div class="relative z-10 aspect-[9/19] bg-zinc-950 rounded-[2.5rem] p-2 shadow-2xl ring-1 ring-white/10 transition-transform duration-500 ease-out group-hover:scale-[1.02]">
      
      <div class="absolute inset-0 rounded-[2.5rem] ring-1 ring-inset ring-white/5 pointer-events-none"></div>

      <div class="absolute top-2 inset-x-0 h-5 z-20 flex justify-center pointer-events-none">
        <div class="w-24 h-full bg-zinc-950 rounded-b-2xl"></div>
      </div>
      
      <div class="w-full h-full rounded-[2rem] overflow-hidden bg-black relative">
        <iframe
          id="hero-video"
          src={`https://www.youtube.com/embed/I96DLrMyilk?enablejsapi=1&origin=${embedOrigin}&autoplay=1&mute=1&loop=1&playlist=I96DLrMyilk&controls=0&playsinline=1&rel=0`}
          title="Vídeo de presentació"
          class="w-full h-full pointer-events-none scale-105 opacity-90 group-hover:opacity-100 transition-opacity duration-500"
          allow="accelerometer; autoplay *; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; compute-pressure"
          allowfullscreen
        ></iframe>
      </div>
    </div>

    <div class="absolute -bottom-5 -left-6 lg:-left-10 bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-white/20 px-4 py-3 z-30 pointer-events-none group-hover:-translate-y-1.5 transition-transform duration-500 ease-out">
      <div class="flex items-center gap-3">
        <div class="flex -space-x-2">
          <div class="w-7 h-7 rounded-full bg-zinc-800 border-2 border-white"></div>
          <div class="w-7 h-7 rounded-full bg-gray-400 border-2 border-white"></div>
          <div class="w-7 h-7 rounded-full bg-brand border-2 border-white"></div>
        </div>
        <div>
          <p class="text-zinc-900 font-extrabold text-xs leading-tight tracking-wide">{t.badgeCount}</p>
          <p class="text-zinc-500 font-medium text-[10px] leading-tight uppercase tracking-wider mt-0.5">{t.badgeLabel}</p>
        </div>
      </div>
    </div>

  </div>
</div>

  </div>
  
</section>

<script>
  let videoMuted = true;

  // Video container click (mute/unmute) via YouTube IFrame API postMessage.
  // Mute/unmute does not trigger the autoplay audio policy block, so postMessage
  // works here without needing to reload the src (which would restart the video).
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('#video-container')) return;
    const iframe = document.getElementById('hero-video') as HTMLIFrameElement | null;
    if (!iframe) return;
    if (videoMuted) {
      iframe.contentWindow?.postMessage(JSON.stringify({ event: 'command', func: 'unMute', args: '' }), '*');
      videoMuted = false;
    } else {
      iframe.contentWindow?.postMessage(JSON.stringify({ event: 'command', func: 'mute', args: '' }), '*');
      videoMuted = true;
    }
  });

  // Reset muted state when navigating away so returning starts muted again
  document.addEventListener('astro:before-preparation', () => {
    videoMuted = true;
  });

  // Hero form — re-attach on each page load so it works after SPA navigation.
  // Module scripts run once per session; astro:page-load fires every navigation.
  function sanitizePhone(input: HTMLInputElement, hintEl?: HTMLElement | null, hintTextId?: string) {
    const hadPlus = input.value.includes('+');
    let val = input.value.replace(/\D/g, '');
    let stripped = hadPlus;
    if ((val.startsWith('34') || val.startsWith('0034')) && val.length > 9) {
      val = val.startsWith('0034') ? val.slice(4) : val.slice(2);
      stripped = true;
    }
    if (val.length > 9) val = val.slice(0, 9);
    input.value = val;

    if (hintEl && stripped) {
      const lang = document.documentElement.lang || 'ca';
      const hintText = hintTextId ? document.getElementById(hintTextId) : null;
      if (hintText) hintText.textContent = lang === 'es'
        ? 'Escribe el teléfono sin prefijo, ej: 687517812'
        : 'Escriu el telèfon sense prefix, ex: 687517812';
      hintEl.classList.remove('hidden');
      hintEl.classList.add('flex');
      clearTimeout((hintEl as any)._hintTimer);
      (hintEl as any)._hintTimer = setTimeout(() => {
        hintEl.classList.add('hidden');
        hintEl.classList.remove('flex');
      }, 3000);
    }
  }

  function setupHeroForm() {
    const heroForm = document.getElementById('hero-form') as HTMLFormElement | null;
    if (!heroForm) return;

    const heroPhoneInput = document.getElementById('hero-phone') as HTMLInputElement | null;
    const heroPhoneHint = document.getElementById('hero-phone-hint') as HTMLElement | null;
    heroPhoneInput?.addEventListener('input', () => sanitizePhone(heroPhoneInput, heroPhoneHint, 'hero-phone-hint-text'));

    heroForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const scriptUrl = heroForm.dataset.scriptUrl;
      if (!scriptUrl) {
        console.error('Apps Script URL no configurada al Hero');
        return;
      }

      const submitBtn = document.getElementById('hero-submit-btn') as HTMLButtonElement;
      const btnText = document.getElementById('hero-btn-text') as HTMLElement;
      const phoneInput = document.getElementById('hero-phone') as HTMLInputElement;
      const successMsg = document.getElementById('hero-success') as HTMLElement;
      const errorMsg = document.getElementById('hero-error') as HTMLElement;

      const phone = phoneInput.value;
      const lang = document.documentElement.lang || 'ca';
      const referit = localStorage.getItem('referit') || '';
      const originalBtnText = btnText.innerText;

      const msgSending = heroForm.dataset.msgSending || 'Enviant...';
      const msgSent = heroForm.dataset.msgSent || 'Enviat!';
      const msgSuccess = heroForm.dataset.msgSuccess || '';
      const msgError = heroForm.dataset.msgError || '';

      submitBtn.disabled = true;
      btnText.innerText = msgSending;
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      try {
        await fetch(scriptUrl, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'create', phone, message: '', lang, canal: 'Web', referit }),
        });

        heroForm.reset();
        successMsg.textContent = msgSuccess;
        successMsg.classList.remove('hidden');
        btnText.innerText = msgSent;

        document.dispatchEvent(new CustomEvent('open-info-modal', { detail: { phone } }));
      } catch {
        errorMsg.textContent = msgError;
        errorMsg.classList.remove('hidden');
        btnText.innerText = originalBtnText;
      } finally {
        setTimeout(() => {
          submitBtn.disabled = false;
          btnText.innerText = originalBtnText;
          successMsg.classList.add('hidden');
        }, 4000);
      }
    });
  }

  document.addEventListener('astro:page-load', setupHeroForm);
</script>

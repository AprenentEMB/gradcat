---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['hero'];
}

const { t } = Astro.props;
---

<section class="bg-white pt-28 pb-20 lg:pt-32 lg:pb-24">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Headline gran a dalt -->
    <div class="mb-10 lg:mb-12">
      <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-5">
        {t.preheadline}
      </p>
      <h1 class="font-display leading-none">
        <span class="block text-5xl sm:text-6xl lg:text-7xl text-navy">
          {t.headline1}
        </span>
        <span class="block text-5xl sm:text-6xl lg:text-7xl text-brand mt-1">
          {t.headline2}
        </span>
      </h1>
    </div>

    <!-- Video + Form -->
    <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-start">

      <!-- Esquerra: Vídeo (3/5) -->
      <div class="lg:col-span-3 relative">
        <div class="aspect-video rounded-2xl overflow-hidden bg-gray-900 shadow-2xl">
          <video
            autoplay
            muted
            loop
            playsinline
            class="w-full h-full object-cover"
          >
            <source src="/hero.mov" type="video/mp4" />
          </video>
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-4 -right-4 bg-white rounded-xl shadow-lg border border-gray-100 px-5 py-3">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-1.5">
              <div class="w-7 h-7 rounded-full bg-brand/10 border-2 border-white"></div>
              <div class="w-7 h-7 rounded-full bg-brand/20 border-2 border-white"></div>
              <div class="w-7 h-7 rounded-full bg-brand/30 border-2 border-white"></div>
            </div>
            <div>
              <p class="text-navy font-bold text-sm">{t.badgeCount}</p>
              <p class="text-gray-400 text-xs">{t.badgeLabel}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Dreta: Subtítol + Form (2/5) -->
      <div class="lg:col-span-2 lg:pt-4">
        <p class="text-gray-500 text-lg leading-relaxed mb-8">
          {t.subtitle}
        </p>

        <!-- Callback form -->
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6">
          <p class="text-navy font-bold text-base mb-4">{t.callbackTitle}</p>
          <form class="flex flex-col gap-3" action="#contacto" method="get">
            <input
              type="tel"
              name="phone"
              maxlength="9"
              placeholder={t.phonePlaceholder}
              class="bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand"
              required
            />
            <button
              type="submit"
              class="bg-brand text-white font-semibold text-sm px-6 py-3 rounded-lg hover:bg-brand-light transition-colors"
            >
              {t.contactBtn}
            </button>
          </form>
          <p class="text-gray-400 text-xs mt-3">
            {t.callbackNote}
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

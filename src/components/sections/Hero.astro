---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['hero'];
}

const { t } = Astro.props;
---

<section class="bg-white pt-28 pb-20 lg:pt-36 lg:pb-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <p class="text-brand font-semibold text-sm tracking-wide uppercase mb-4">

        </p>

        <h1 class="text-4xl sm:text-4xl lg:text-4xl font-display text-navy leading-[1.05] mb-6">
          {t.headline1}
        </h1>

        <h1 class="text-4xl sm:text-4xl lg:text-4xl text-navy mb-6 font-display">
          {t.headline2}
        </h1>

        <p class="text-gray-500 text-lg leading-relaxed mb-8 max-w-lg">
          {t.subtitle}
        </p>

        <!-- Callback form -->
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 max-w-md">
          <p class="text-navy font-bold text-base mb-4">{t.callbackTitle}</p>
          <form class="flex flex-col sm:flex-row gap-3" action="#contacto" method="get">
            <input
              type="tel"
              name="phone"
              placeholder={t.phonePlaceholder}
              class="flex-1 bg-white border border-gray-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand"
              required
            />
            <button
              type="submit"
              class="bg-brand text-white font-semibold text-sm px-6 py-3 rounded-lg hover:bg-brand-light transition-colors whitespace-nowrap"
            >
              {t.contactBtn}
            </button>
          </form>
          <p class="text-gray-400 text-xs mt-3">
            {t.callbackNote}
          </p>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="relative">
        <div class="aspect-4/3 rounded-2xl overflow-hidden bg-gray-100">
          <img
            src="https://images.pexels.com/photos/267885/pexels-photo-267885.jpeg?auto=compress&cs=tinysrgb&w=1200"
            alt="Fiesta de graduación en Barcelona"
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg border border-gray-100 px-5 py-3">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-1.5">
              <div class="w-7 h-7 rounded-full bg-brand/10 border-2 border-white"></div>
              <div class="w-7 h-7 rounded-full bg-brand/20 border-2 border-white"></div>
              <div class="w-7 h-7 rounded-full bg-brand/30 border-2 border-white"></div>
            </div>
            <div>
              <p class="text-navy font-bold text-sm">{t.badgeCount}</p>
              <p class="text-gray-400 text-xs">{t.badgeLabel}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

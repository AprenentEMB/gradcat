---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['hero'];
}

const { t } = Astro.props;

const appsScriptUrl = import.meta.env.PUBLIC_APPS_SCRIPT_URL ?? '';
---

<section class="bg-white pt-24 pb-20 lg:pt-32 lg:pb-24 px-6">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-8">

    <!-- Left: Text + Form -->
    <div class="flex-1 min-w-0 flex flex-col items-center lg:items-start">

      <!-- Pre-headline -->
      <p class="text-brand font-semibold text-xs lg:text-sm tracking-widest uppercase mb-4 text-center lg:text-left">
        {t.preheadline}
      </p>

      <!-- Headline -->
      <h1 class="font-display text-navy leading-[1.15] mb-5 lg:mb-6 text-center lg:text-left">
        <span class="block text-4xl sm:text-5xl lg:text-5xl font-bold italic">
          {t.headline1}
        </span>
        <span class="block text-4xl sm:text-5xl lg:text-5xl font-bold italic bg-gradient-to-r from-brand-dark via-brand to-brand-light bg-clip-text text-transparent pb-6">
          {t.headline2}
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="text-gray-500 text-base lg:text-lg leading-relaxed max-w-md mb-8 lg:mb-10 text-center lg:text-left">
        {t.subtitle}
      </p>

      <!-- Callback form card -->
      <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5 sm:p-6 w-full max-w-md shadow-sm">
        <p class="text-navy font-bold text-base lg:text-lg mb-4 text-center lg:text-left">{t.callbackTitle}</p>
        <form id="hero-form" class="flex flex-col sm:flex-row gap-2 sm:gap-3" data-script-url={appsScriptUrl} data-msg-success={t.formSuccess} data-msg-error={t.formError} data-msg-sending={t.formSending} data-msg-sent={t.formSent}>
          {/* Honeypot antispam */}
          <input type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" />
          <input
            type="tel"
            id="hero-phone"
            name="phone"
            maxlength="9"
            placeholder={t.phonePlaceholder}
            class="flex-1 min-w-0 bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand shadow-inner"
            required
          />
          <button
            type="submit"
            id="hero-submit-btn"
            class="w-full sm:w-auto bg-brand text-white font-semibold text-sm px-5 py-3 rounded-xl hover:bg-brand-light transition-all shadow-md hover:shadow-lg whitespace-nowrap cursor-pointer touch-manipulation"
          >
            <span id="hero-btn-text">{t.contactBtn}</span>
          </button>
        </form>
        <div id="hero-success" class="hidden mt-3 text-green-600 text-xs font-medium"></div>
        <div id="hero-error" class="hidden mt-3 text-red-600 text-xs font-medium"></div>
        <p class="text-gray-400 text-xs mt-3 leading-relaxed">
          {t.callbackNote}
        </p>
      </div>

    </div>

    <!-- Right: Phone -->
    <div class="flex-shrink-0 flex justify-center lg:justify-end relative pb-8 lg:pb-0">
      <div class="relative w-[220px] sm:w-[240px] lg:w-[280px] group cursor-pointer" id="video-container">

        <!-- Phone frame -->
        <div class="relative aspect-[9/19] bg-gray-900 rounded-[2.5rem] p-2 shadow-2xl ring-1 ring-gray-900/10 transition-transform duration-300 group-hover:scale-[1.02]">
          <!-- Notch -->
          <div class="absolute top-2 inset-x-0 h-5 z-20 flex justify-center pointer-events-none">
            <div class="w-24 h-full bg-gray-900 rounded-b-2xl"></div>
          </div>
          <!-- Screen -->
          <div class="w-full h-full rounded-[2rem] overflow-hidden bg-black relative">
            <iframe
              id="hero-video"
              src="https://www.youtube.com/embed/I96DLrMyilk?enablejsapi=1&autoplay=1&mute=1&loop=1&playlist=I96DLrMyilk&controls=0&playsinline=1&rel=0"
              title="Vídeo de presentació"
              class="w-full h-full pointer-events-none scale-105"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-5 -left-6 lg:-left-10 bg-white rounded-2xl shadow-xl border border-gray-100 px-4 py-3 z-30 pointer-events-none">
          <div class="flex items-center gap-3">
            <div class="flex -space-x-2">
              <div class="w-7 h-7 rounded-full bg-brand/20 border-2 border-white"></div>
              <div class="w-7 h-7 rounded-full bg-brand/35 border-2 border-white"></div>
              <div class="w-7 h-7 rounded-full bg-brand/50 border-2 border-white"></div>
            </div>
            <div>
              <p class="text-navy font-bold text-xs leading-tight">{t.badgeCount}</p>
              <p class="text-gray-400 text-[10px] leading-tight">{t.badgeLabel}</p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  let player: any;

  const tag = document.createElement('script');
  tag.src = "https://www.youtube.com/iframe_api";
  const firstScriptTag = document.getElementsByTagName('script')[0];
  if (firstScriptTag && firstScriptTag.parentNode) {
    firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
  }

  (window as any).onYouTubeIframeAPIReady = () => {
    player = new (window as any).YT.Player('hero-video', {
      events: {
        'onReady': (_event: any) => {}
      }
    });
  };

  const container = document.getElementById('video-container');
  if (container) {
    container.addEventListener('click', () => {
      if (player && typeof player.unMute === 'function') {
        if (player.isMuted()) {
          player.unMute();
          player.setVolume(100);
        } else {
          player.mute();
        }
      }
    });
  }

  // Hero form -> Sheets
  const heroForm = document.getElementById('hero-form') as HTMLFormElement | null;
  if (heroForm) {
    heroForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const scriptUrl = heroForm.dataset.scriptUrl;
      if (!scriptUrl) {
        console.error('Apps Script URL no configurada al Hero');
        return;
      }

      const submitBtn = document.getElementById('hero-submit-btn') as HTMLButtonElement;
      const btnText = document.getElementById('hero-btn-text') as HTMLElement;
      const phoneInput = document.getElementById('hero-phone') as HTMLInputElement;
      const successMsg = document.getElementById('hero-success') as HTMLElement;
      const errorMsg = document.getElementById('hero-error') as HTMLElement;

      const phone = phoneInput.value;
      const lang = document.documentElement.lang || 'ca';
      const originalBtnText = btnText.innerText;

      const msgSending = heroForm.dataset.msgSending || 'Enviant...';
      const msgSent = heroForm.dataset.msgSent || 'Enviat!';
      const msgSuccess = heroForm.dataset.msgSuccess || '';
      const msgError = heroForm.dataset.msgError || '';

      submitBtn.disabled = true;
      btnText.innerText = msgSending;
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      try {
        await fetch(scriptUrl, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone, message: '', lang }),
        });

        heroForm.reset();
        successMsg.textContent = msgSuccess;
        successMsg.classList.remove('hidden');
        btnText.innerText = msgSent;
      } catch {
        errorMsg.textContent = msgError;
        errorMsg.classList.remove('hidden');
        btnText.innerText = originalBtnText;
      } finally {
        setTimeout(() => {
          submitBtn.disabled = false;
          btnText.innerText = originalBtnText;
          successMsg.classList.add('hidden');
        }, 4000);
      }
    });
  }
</script>

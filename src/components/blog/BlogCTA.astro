---
import type { Translations } from '../../i18n/translations';

interface Props {
  t: Translations['hero'];
}

const { t } = Astro.props;

const appsScriptUrl = import.meta.env.PUBLIC_APPS_SCRIPT_URL ?? '';
---

<div class="mt-12 mb-8 bg-gray-50 border border-gray-200 rounded-2xl p-6 sm:p-8 shadow-sm">
  <p class="text-navy font-bold text-lg sm:text-xl mb-2 text-center">{t.callbackTitle}</p>
  <p class="text-gray-500 text-sm text-center mb-5">{t.callbackNote}</p>

  <form
    id="blog-cta-form"
    class="flex flex-col sm:flex-row gap-2 sm:gap-3 max-w-md mx-auto"
    data-script-url={appsScriptUrl}
    data-msg-success={t.formSuccess}
    data-msg-error={t.formError}
    data-msg-sending={t.formSending}
    data-msg-sent={t.formSent}
  >
    <input type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" />
    <input
      type="tel"
      id="blog-cta-phone"
      name="phone"
      maxlength="9"
      pattern="[6789][0-9]{8}"
      placeholder={t.phonePlaceholder}
      class="flex-1 min-w-0 bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand shadow-inner"
      required
    />
    <button
      type="submit"
      id="blog-cta-submit-btn"
      class="w-full sm:w-auto bg-brand text-white font-semibold text-sm px-6 py-3 rounded-xl hover:bg-brand-light transition-all shadow-md hover:shadow-lg whitespace-nowrap cursor-pointer touch-manipulation disabled:opacity-70 disabled:cursor-not-allowed"
    >
      <span id="blog-cta-btn-text">{t.contactBtn}</span>
    </button>
  </form>

  <div id="blog-cta-phone-hint" class="hidden mt-2 text-xs text-blue-500 items-center gap-1 max-w-md mx-auto">
    <svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/></svg>
    <span id="blog-cta-phone-hint-text"></span>
  </div>
  <div id="blog-cta-success" class="hidden mt-3 text-green-600 text-xs font-medium text-center max-w-md mx-auto"></div>
  <div id="blog-cta-error" class="hidden mt-3 text-red-600 text-xs font-medium text-center max-w-md mx-auto"></div>
</div>

<script>
  function sanitizeBlogCtaPhone(input: HTMLInputElement, hintEl?: HTMLElement | null, hintTextId?: string) {
    const hadPlus = input.value.includes('+');
    let val = input.value.replace(/\D/g, '');
    let stripped = hadPlus;
    if ((val.startsWith('34') || val.startsWith('0034')) && val.length > 9) {
      val = val.startsWith('0034') ? val.slice(4) : val.slice(2);
      stripped = true;
    }
    if (val.length > 9) val = val.slice(0, 9);
    input.value = val;

    if (hintEl && stripped) {
      const lang = document.documentElement.lang || 'ca';
      const hintText = hintTextId ? document.getElementById(hintTextId) : null;
      if (hintText) hintText.textContent = lang === 'es'
        ? 'Escribe el teléfono sin prefijo, ej: 687517812'
        : 'Escriu el telèfon sense prefix, ex: 687517812';
      hintEl.classList.remove('hidden');
      hintEl.classList.add('flex');
      clearTimeout((hintEl as any)._hintTimer);
      (hintEl as any)._hintTimer = setTimeout(() => {
        hintEl.classList.add('hidden');
        hintEl.classList.remove('flex');
      }, 3000);
    }
  }

  function setupBlogCta() {
    const form = document.getElementById('blog-cta-form') as HTMLFormElement | null;
    if (!form) return;

    const phoneInput = document.getElementById('blog-cta-phone') as HTMLInputElement | null;
    const phoneHint = document.getElementById('blog-cta-phone-hint') as HTMLElement | null;
    phoneInput?.addEventListener('input', () => sanitizeBlogCtaPhone(phoneInput, phoneHint, 'blog-cta-phone-hint-text'));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const scriptUrl = form.dataset.scriptUrl;
      if (!scriptUrl) return;

      const submitBtn = document.getElementById('blog-cta-submit-btn') as HTMLButtonElement;
      const btnText = document.getElementById('blog-cta-btn-text') as HTMLElement;
      const successMsg = document.getElementById('blog-cta-success') as HTMLElement;
      const errorMsg = document.getElementById('blog-cta-error') as HTMLElement;

      const phone = (document.getElementById('blog-cta-phone') as HTMLInputElement).value;
      const lang = document.documentElement.lang || 'ca';
      const referit = localStorage.getItem('referit') || '';
      const originalBtnText = btnText.innerText;

      const msgSending = form.dataset.msgSending || 'Enviant...';
      const msgSent = form.dataset.msgSent || 'Enviat!';
      const msgSuccess = form.dataset.msgSuccess || '';
      const msgError = form.dataset.msgError || '';

      submitBtn.disabled = true;
      btnText.innerText = msgSending;
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      try {
        await fetch(scriptUrl, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'create', phone, message: '', lang, canal: 'Web', referit }),
        });

        form.reset();
        successMsg.textContent = msgSuccess;
        successMsg.classList.remove('hidden');
        btnText.innerText = msgSent;

        document.dispatchEvent(new CustomEvent('open-info-modal', { detail: { phone } }));
      } catch {
        errorMsg.textContent = msgError;
        errorMsg.classList.remove('hidden');
        btnText.innerText = originalBtnText;
      } finally {
        setTimeout(() => {
          submitBtn.disabled = false;
          btnText.innerText = originalBtnText;
          successMsg.classList.add('hidden');
        }, 4000);
      }
    });
  }

  document.addEventListener('astro:page-load', setupBlogCta);
</script>

---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import ContactModal from '../components/ui/ContactModal.astro';
import InfoModal from '../components/ui/InfoModal.astro';
import { ClientRouter } from 'astro:transitions';
import type { Lang } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  skipToContent: string;
  image?: string;
}

const {
  title,
  description,
  lang,
  skipToContent,
  image = '/images/og-image.jpg',
} = Astro.props;

const appsScriptUrl = import.meta.env.PUBLIC_APPS_SCRIPT_URL ?? '';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <SEO title={title} description={description} image={image} lang={lang} />

    <ClientRouter />

    <meta name="theme-color" content="#173696" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://i.ytimg.com" />
    <link rel="dns-prefetch" href="https://www.youtube.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fonts: preload injected once per browser session via script to avoid
         Astro ClientRouter re-inserting it on every SPA navigation, which
         triggers repeated "preloaded but not used" browser warnings. -->
    <script is:inline>
      if (!window.__fontPreloaded) {
        window.__fontPreloaded = true;
        var l = document.createElement('link');
        l.rel = 'preload';
        l.href = '/fonts/Corra%20Montserra/WOFF2/Corra%20Montserra%20Medium.woff2';
        l.as = 'font';
        l.type = 'font/woff2';
        l.crossOrigin = 'anonymous';
        document.head.appendChild(l);
      }
    </script>
    <!-- Load Google Fonts non-blocking to avoid render-blocking penalty -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;800&display=swap" /></noscript>

    <!-- Referral tracking: capture ?ref=XXX from URL and persist in sessionStorage -->
    <script is:inline>
      (function () {
        var params = new URLSearchParams(window.location.search);
        var ref = params.get('ref');
        if (ref) sessionStorage.setItem('referit', ref);
      })();
    </script>
    <script>
      document.addEventListener('astro:page-load', () => {
        var params = new URLSearchParams(window.location.search);
        var ref = params.get('ref');
        if (ref) sessionStorage.setItem('referit', ref);
      });
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LGSRT4G7R7" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LGSRT4G7R7', {
        cookie_flags: 'SameSite=Lax;Secure',
      });
    </script>
    <!-- Track SPA navigations with ClientRouter -->
    <script>
      let initialLoad = true;
      document.addEventListener('astro:page-load', () => {
        if (initialLoad) { initialLoad = false; return; }
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('config', 'G-LGSRT4G7R7', {
            page_path: window.location.pathname,
          });
        }
      });
    </script>

    <slot name="head" />

    <!-- Local Business structured data -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Graduacions.cat",
        "alternateName": "GRAD-CAT",
        "description": "Organizamos fiestas de graduación en Barcelona. ESO, Bachillerato y Selectividad.",
        "url": "https://www.graduacions.cat",
        "telephone": "+34605508397",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Barcelona",
          "addressRegion": "Catalunya",
          "addressCountry": "ES"
        },
        "areaServed": {
          "@type": "City",
          "name": "Barcelona"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "347",
          "bestRating": "5"
        }
      }
    </script>
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-brand focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg"
    >
      {skipToContent}
    </a>
    <slot />
    <ContactModal lang={lang} appsScriptUrl={appsScriptUrl} transition:persist="contact-modal" />
    <InfoModal lang={lang} appsScriptUrl={appsScriptUrl} transition:persist="info-modal" />
    <script>
      (function () {
        var lang = document.documentElement.lang || 'ca';
        var msg = lang === 'ca' ? 'Completa aquest camp' : 'Completa este campo';
        document.addEventListener('invalid', function (e) {
          var el = e.target as HTMLInputElement | null;
          if (el && typeof el.setCustomValidity === 'function') {
            el.setCustomValidity(msg);
          }
        }, true);
        document.addEventListener('input', function (e) {
          var el = e.target as HTMLInputElement | null;
          if (el && typeof el.setCustomValidity === 'function') {
            el.setCustomValidity('');
          }
        }, true);
      })();
    </script>
  </body>
</html>

---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import type { Lang } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  skipToContent: string;
  image?: string;
}

const {
  title,
  description,
  lang,
  skipToContent,
  image = '/images/og-image.jpg',
} = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <SEO title={title} description={description} image={image} lang={lang} />

    <meta name="theme-color" content="#173696" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Fonts -->
    <link rel="preload" href="/fonts/Corra Montserra/VARIABLE/Cora Montserra Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LGSRT4G7R7" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LGSRT4G7R7');
    </script>

    <!-- Local Business structured data -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "EventPlanner",
        "name": "Graduacions.cat",
        "alternateName": "GRAD-CAT",
        "description": "Organizamos fiestas de graduación en Barcelona. ESO, Bachillerato y Selectividad.",
        "url": "https://graduacions.cat",
        "telephone": "+34605508397",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Barcelona",
          "addressRegion": "Catalunya",
          "addressCountry": "ES"
        },
        "areaServed": {
          "@type": "City",
          "name": "Barcelona"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "347",
          "bestRating": "5"
        }
      }
    </script>
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <!-- Google Tag Manager (noscript) -->
    <noscript is:raw><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MTBJLLX3" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-brand focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg"
    >
      {skipToContent}
    </a>
    <slot />
  </body>
</html>

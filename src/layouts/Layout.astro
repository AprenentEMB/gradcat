---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import ContactModal from '../components/ui/ContactModal.astro';
import InfoModal from '../components/ui/InfoModal.astro';
import CookieBanner from '../components/ui/CookieBanner.astro';
import { ClientRouter } from 'astro:transitions';
import type { Lang } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  skipToContent: string;
  image?: string;
}

const {
  title,
  description,
  lang,
  skipToContent,
  image = '/images/og-image.jpg',
} = Astro.props;

const appsScriptUrl = import.meta.env.PUBLIC_APPS_SCRIPT_URL ?? '';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <SEO title={title} description={description} image={image} lang={lang} />

    <ClientRouter />

    <meta name="theme-color" content="#173696" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Preconnect to YouTube thumbnails (no personal data, no cookies) -->
    <link rel="preconnect" href="https://i.ytimg.com" />

    <!-- Fonts: preload injected once per browser session via script to avoid
         Astro ClientRouter re-inserting it on every SPA navigation, which
         triggers repeated "preloaded but not used" browser warnings. -->
    <script is:inline>
      if (!window.__fontPreloaded) {
        window.__fontPreloaded = true;
        var l = document.createElement('link');
        l.rel = 'preload';
        l.href = '/fonts/Corra%20Montserra/WOFF2/Corra%20Montserra%20Medium.woff2';
        l.as = 'font';
        l.type = 'font/woff2';
        l.crossOrigin = 'anonymous';
        document.head.appendChild(l);
      }
    </script>
    <!-- Analytics + Referral: only activated after cookie consent -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      window.__loadGA = function () {
        if (window.__gaLoaded) return;
        window.__gaLoaded = true;
        var pc = document.createElement('link');
        pc.rel = 'preconnect';
        pc.href = 'https://www.googletagmanager.com';
        document.head.appendChild(pc);
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-LGSRT4G7R7';
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', 'G-LGSRT4G7R7', { cookie_flags: 'SameSite=Lax;Secure' });
      };

      window.__loadReferral = function () {
        try {
          var params = new URLSearchParams(window.location.search);
          var ref = params.get('ref');
          if (ref) {
            localStorage.setItem('referit', ref);
          } else {
            var stored = localStorage.getItem('referit');
            if (stored) {
              var url = new URL(window.location.href);
              url.searchParams.set('ref', stored);
              history.replaceState(null, '', url.toString());
            }
          }
        } catch (e) {}
      };

      (function () {
        var c = null;
        try { c = localStorage.getItem('cookie_consent'); } catch (e) {}
        if (c === 'accepted') {
          window.__loadGA();
          window.__loadReferral();
        }
      })();
    </script>
    <!-- SPA: referral + GA page tracking on each navigation -->
    <script>
      let initialLoad = true;
      document.addEventListener('astro:page-load', () => {
        try {
          if (localStorage.getItem('cookie_consent') === 'accepted') {
            (window as any).__loadReferral?.();
            if (!initialLoad && (window as any).__gaLoaded) {
              (window as any).gtag?.('config', 'G-LGSRT4G7R7', {
                page_path: window.location.pathname,
              });
            }
          }
        } catch (e) {}
        initialLoad = false;
      });
    </script>

    <slot name="head" />

    <!-- Local Business structured data -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Graduacions.cat",
        "alternateName": "GRAD-CAT",
        "description": "Organizamos fiestas de graduación en Barcelona. ESO, Bachillerato y Selectividad.",
        "url": "https://www.graduacions.cat",
        "telephone": "+34605508397",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Barcelona",
          "addressRegion": "Catalunya",
          "addressCountry": "ES"
        },
        "areaServed": {
          "@type": "City",
          "name": "Barcelona"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "347",
          "bestRating": "5"
        }
      }
    </script>
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-brand focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg"
    >
      {skipToContent}
    </a>
    <slot />
    <ContactModal lang={lang} appsScriptUrl={appsScriptUrl} transition:persist="contact-modal" />
    <InfoModal lang={lang} appsScriptUrl={appsScriptUrl} transition:persist="info-modal" />
    <CookieBanner lang={lang} transition:persist="cookie-banner" />
    <script>
      (function () {
        var lang = document.documentElement.lang || 'ca';
        var msg = lang === 'ca' ? 'Completa aquest camp' : 'Completa este campo';
        document.addEventListener('invalid', function (e) {
          var el = e.target as HTMLInputElement | null;
          if (el && typeof el.setCustomValidity === 'function') {
            el.setCustomValidity(msg);
          }
        }, true);
        document.addEventListener('input', function (e) {
          var el = e.target as HTMLInputElement | null;
          if (el && typeof el.setCustomValidity === 'function') {
            el.setCustomValidity('');
          }
        }, true);
      })();
    </script>
  </body>
</html>

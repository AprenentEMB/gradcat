---
export const prerender = true;

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/sections/Header.astro';
import Footer from '../../../components/sections/Footer.astro';
import { fetchStrapi, getStrapiMediaUrl } from '../../../lib/strapi';
import type { Article, StrapiListResponse } from '../../../lib/strapi';
import { translations } from '../../../i18n/translations';
import fallbackImg from '../../../assets/blog/1.webp';
const t = translations.es;

const { data: articles } = await fetchStrapi<StrapiListResponse<Article>>(
  '/articles?sort=publishedAt:desc&pagination[pageSize]=100&populate=image&locale=es'
);
---

<Layout
  title="Blog — Graduacions.cat"
  description="Consejos, ideas e inspiración para organizar la mejor fiesta de graduación en Barcelona."
  lang="es"
  skipToContent={t.layout.skipToContent}
>
  <Header t={t.header} lang="es" />

  <main id="main-content">

    <!-- Hero -->
    <section class="bg-linear-to-br from-white via-white to-brand/5 pt-32 pb-16 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-brand font-semibold text-xs tracking-widest uppercase mb-4">Graduacions.cat</p>
        <h1 class="font-headline leading-tight mb-4">
          <span class="block text-4xl md:text-5xl tracking-tight text-gray-500 mb-2" style="font-weight:200">Nuestro</span>
          <span class="block text-5xl md:text-6xl tracking-tighter bg-linear-to-r from-brand-dark via-brand to-blue-400 bg-clip-text text-transparent pb-2" style="font-weight:800">Blog</span>
        </h1>
        <p class="font-light text-gray-500 text-lg max-w-xl mx-auto">
          Consejos, ideas e inspiración para organizar la fiesta de graduación perfecta.
        </p>
      </div>
    </section>

    <section class="bg-gray-50 px-6 py-16">
      <div class="max-w-6xl mx-auto">

        {articles.length === 0 ? (
          <div class="text-center py-20">
            <p class="text-gray-400 text-lg">Pronto publicaremos nuevos artículos. ¡Vuelve pronto!</p>
          </div>
        ) : (
          <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3" role="list">
            {articles.map((article, i) => (
              <li class="flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100">

                <a href={`/es/blog/${article.slug}`} tabindex="-1" aria-hidden="true">
                  <img
                    src={article.image ? getStrapiMediaUrl(article.image.url) : fallbackImg.src}
                    alt={article.image?.alternativeText ?? article.title}
                    width={article.image?.width ?? fallbackImg.width}
                    height={article.image?.height ?? fallbackImg.height}
                    class="w-full h-48 object-cover"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    transition:name={`post-image-es-${article.slug}`}
                  />
                </a>

                <div class="h-1 bg-linear-to-r from-brand to-brand-light"></div>

                <div class="flex flex-col flex-1 p-6">
                  {article.publishedAt && (
                    <time datetime={article.publishedAt} class="text-xs text-gray-400 font-medium mb-2 uppercase tracking-wide">
                      {new Date(article.publishedAt).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  )}

                  <h2 class="text-lg font-bold text-gray-900 mb-2 leading-snug">
                    <a href={`/es/blog/${article.slug}`} class="hover:text-brand transition-colors focus:outline-none focus:underline">
                      {article.title}
                    </a>
                  </h2>

                  {article.description && (
                    <p class="text-gray-500 text-sm flex-1 mb-4 line-clamp-3">{article.description}</p>
                  )}

                  <a
                    href={`/es/blog/${article.slug}`}
                    class="mt-auto inline-flex items-center gap-1.5 text-sm font-semibold text-brand hover:text-brand-light transition-colors"
                    aria-label={`Leer: ${article.title}`}
                  >
                    Leer artículo
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

  </main>

  <Footer t={t.footer} />
</Layout>

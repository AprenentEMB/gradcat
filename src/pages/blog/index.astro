---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import { fetchStrapi, getStrapiMediaUrl } from '../../lib/strapi';
import type { Article, StrapiListResponse } from '../../lib/strapi';
import { translations } from '../../i18n/translations';
import bgImage from '../../assets/graduacions/2.webp';

const t = translations.ca;

const { data: articles } = await fetchStrapi<StrapiListResponse<Article>>(
  '/articles?sort=publishedAt:desc&pagination[pageSize]=100&populate=image&locale=ca-ES'
);
---

<Layout
  title="Blog — Graduacions.cat"
  description="Consells, idees i inspiració per organitzar la millor festa de graduació a Barcelona."
  lang="ca"
  skipToContent={t.layout.skipToContent}
>
  <Header t={t.header} lang="ca" />

  <main id="main-content">

    <!-- Hero -->
    <section class="relative pt-32 pb-16 px-6 overflow-hidden">
      <img
        src={bgImage.src}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover object-top"
        loading="eager"
        fetchpriority="high"
        width={bgImage.width}
        height={bgImage.height}
      />
      <div class="absolute inset-0 bg-gray-900/65"></div>
      <div class="relative max-w-4xl mx-auto text-center">
        <p class="text-white/60 text-sm font-semibold uppercase tracking-widest mb-3">Graduacions.cat</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
          Blog
        </h1>
        <p class="text-white/70 text-lg max-w-xl mx-auto">
          Consells, idees i inspiració per organitzar la festa de graduació perfecta.
        </p>
      </div>
    </section>

    <!-- Articles -->
    <section class="bg-gray-50 px-6 py-16">
      <div class="max-w-6xl mx-auto">

        {articles.length === 0 ? (
          <div class="text-center py-20">
            <p class="text-gray-400 text-lg">Aviat publicarem nous articles. Torna aviat!</p>
          </div>
        ) : (
          <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3" role="list">
            {articles.map((article, i) => (
              <li class="flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100">

                <!-- Image -->
                {article.image ? (
                  <a href={`/blog/${article.slug}`} tabindex="-1" aria-hidden="true">
                    <img
                      src={getStrapiMediaUrl(article.image.url)}
                      alt={article.image.alternativeText ?? article.title}
                      width={article.image.width}
                      height={article.image.height}
                      class="w-full h-48 object-cover"
                      loading={i === 0 ? 'eager' : 'lazy'}
                      transition:name={`post-image-${article.slug}`}
                    />
                  </a>
                ) : (
                  <a href={`/blog/${article.slug}`} tabindex="-1" aria-hidden="true">
                    <div class="w-full h-48 bg-linear-to-br from-brand to-brand-light flex items-center justify-center">
                      <svg class="w-12 h-12 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                      </svg>
                    </div>
                  </a>
                )}

                <!-- Brand accent line -->
                <div class="h-1 bg-linear-to-r from-brand to-brand-light"></div>

                <div class="flex flex-col flex-1 p-6">
                  <!-- Date -->
                  {article.publishedAt && (
                    <time datetime={article.publishedAt} class="text-xs text-gray-400 font-medium mb-2 uppercase tracking-wide">
                      {new Date(article.publishedAt).toLocaleDateString('ca-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  )}

                  <!-- Title -->
                  <h2 class="text-lg font-bold text-gray-900 mb-2 leading-snug">
                    <a href={`/blog/${article.slug}`} class="hover:text-brand transition-colors focus:outline-none focus:underline">
                      {article.title}
                    </a>
                  </h2>

                  <!-- Description -->
                  {article.description && (
                    <p class="text-gray-500 text-sm flex-1 mb-4 line-clamp-3">{article.description}</p>
                  )}

                  <!-- CTA -->
                  <a
                    href={`/blog/${article.slug}`}
                    class="mt-auto inline-flex items-center gap-1.5 text-sm font-semibold text-brand hover:text-brand-light transition-colors"
                    aria-label={`Llegir: ${article.title}`}
                  >
                    Llegir article
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

  </main>

  <Footer t={t.footer} />
</Layout>

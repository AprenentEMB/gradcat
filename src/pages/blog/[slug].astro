---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import BlogCTA from '../../components/blog/BlogCTA.astro';
import { fetchStrapi, getStrapiMediaUrl, blocksToHtml } from '../../lib/strapi';
import type { Article, StrapiListResponse } from '../../lib/strapi';
import { translations } from '../../i18n/translations';
import fallbackImg from '../../assets/blog/1.webp';

const blogImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/blog/*.webp', { eager: true });

const t = translations.ca;

export async function getStaticPaths() {
  const { data: articles } = await fetchStrapi<StrapiListResponse<Article>>(
    '/articles?fields[0]=slug&fields[1]=title&pagination[pageSize]=100&locale=ca-ES'
  );
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { slug } = Astro.params;

const { data: articles } = await fetchStrapi<StrapiListResponse<Article>>(
  `/articles?filters[slug][$eq]=${slug}&populate=image&pagination[pageSize]=1&locale=ca-ES`
);

const article = articles[0];

if (!article) return Astro.redirect('/blog');

const slugImg = blogImages[`../../assets/blog/${article.slug}.webp`];
const coverUrl = slugImg ? slugImg.default.src : fallbackImg.src;
const contentHtml = blocksToHtml(article.content);

const articleSchema = article ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.description ?? article.title,
  ...(coverUrl ? { image: coverUrl } : {}),
  datePublished: article.publishedAt,
  publisher: {
    '@type': 'Organization',
    name: 'Graduacions.cat',
    url: 'https://www.graduacions.cat',
  },
} : null;
---

<Layout
  title={`${article.title} — Blog Graduacions.cat`}
  description={article.description ?? article.title}
  lang="ca"
  skipToContent={t.layout.skipToContent}
  image={coverUrl}
>
  {articleSchema && (
    <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  )}
  <Header t={t.header} lang="ca" />

  <main id="main-content">

    <!-- Hero amb imatge o gradient de brand -->
    <div class="relative bg-brand pt-24 pb-0">

      {coverUrl ? (
        <>
          <!-- Overlay fosc sobre la imatge -->
          <div class="absolute inset-0 overflow-hidden">
            <img
              src={coverUrl}
              alt={article.image?.alternativeText ?? article.title}
              class="w-full h-full object-cover opacity-20"
              loading="eager"
            />
          </div>
          <div class="relative max-w-3xl mx-auto px-6 pt-8 pb-16 text-center">
            <a href="/blog" class="inline-flex items-center gap-1.5 text-white/60 hover:text-white text-sm font-medium transition-colors mb-6">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
              </svg>
              Tornar al blog
            </a>
            <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-4">{article.title}</h1>
            {article.publishedAt && (
              <time datetime={article.publishedAt} class="text-white/60 text-sm">
                {new Date(article.publishedAt).toLocaleDateString('ca-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            )}
          </div>
        </>
      ) : (
        <div class="relative max-w-3xl mx-auto px-6 pt-8 pb-16 text-center">
          <a href="/blog" class="inline-flex items-center gap-1.5 text-white/60 hover:text-white text-sm font-medium transition-colors mb-6">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Tornar al blog
          </a>
          <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-4">{article.title}</h1>
          {article.publishedAt && (
            <time datetime={article.publishedAt} class="text-white/60 text-sm">
              {new Date(article.publishedAt).toLocaleDateString('ca-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          )}
        </div>
      )}

      <!-- Wave cap avall -->
      <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-full -mb-1">
        <path d="M0 40 C360 0 1080 0 1440 40 L1440 40 L0 40 Z" fill="white"/>
      </svg>
    </div>

    <!-- Imatge destacada (si n'hi ha) sota el hero -->
    {coverUrl && (
      <div class="max-w-3xl mx-auto px-6 -mt-6 mb-10 relative z-10">
        <img
          src={coverUrl}
          alt={article.image?.alternativeText ?? article.title}
          width={article.image?.width}
          height={article.image?.height}
          class="w-full rounded-2xl object-cover max-h-80 shadow-lg"
          loading="eager"
          fetchpriority="high"
          transition:name={`post-image-${article.slug}`}
        />
      </div>
    )}

    <!-- Contingut -->
    <article class="max-w-3xl mx-auto px-6 pb-20">
      <div class="prose max-w-none text-gray-700">
        <Fragment set:html={contentHtml} />
      </div>

      <BlogCTA t={t.hero} />

      <!-- Back link al final -->
      <div class="mt-0 pt-8 border-t border-gray-100">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-semibold text-brand hover:text-brand-light transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Veure tots els articles
        </a>
      </div>
    </article>

  </main>

  <Footer t={t.footer} />
</Layout>

# Copy this file to .env and fill in your secrets. Never commit .env to git.

# Google Apps Script (contact form)
PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# WhatsApp Business Cloud API — server-only (no PUBLIC_ prefix)
WHATSAPP_TOKEN=your_system_user_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Strapi CMS
# Base URL of your Strapi instance (no trailing slash)
PUBLIC_STRAPI_URL=http://localhost:1337
# API token generated in Strapi Admin → Settings → API Tokens (server-only)
STRAPI_TOKEN=your_strapi_api_token
